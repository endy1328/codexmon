# systemd wrapper
CODEXMON_ENV_FILE=/home/u24/projects/codexmon/.env
CODEXMON_PYTHON_BIN=/usr/bin/python3

# daemon baseline
CODEXMON_DAEMON_POLL_INTERVAL_SECONDS=15
CODEXMON_LOG_LEVEL=INFO

# optional overrides
CODEXMON_DB_PATH=/home/u24/projects/codexmon/.codexmon/codexmon.db
CODEXMON_REPO_PATH=/home/u24/projects/codexmon
CODEXMON_WORKTREE_ROOT=/home/u24/projects/codexmon/.codexmon/worktrees
