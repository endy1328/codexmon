# codexmon local runtime
CODEXMON_LOG_LEVEL=INFO
CODEXMON_DB_PATH=.codexmon/codexmon.db
CODEXMON_REPO_PATH=.
CODEXMON_WORKTREE_ROOT=.codexmon/worktrees
CODEXMON_CODEX_COMMAND=codex
CODEXMON_CODEX_MODEL=
CODEXMON_CODEX_SANDBOX=workspace-write
CODEXMON_AUTOMATIC_RETRY_BUDGET=1
CODEXMON_IDLE_TIMEOUT_SECONDS=900
CODEXMON_WALL_CLOCK_TIMEOUT_SECONDS=7200

# GitHub handoff
CODEXMON_GITHUB_OWNER=
CODEXMON_GITHUB_REPO=
CODEXMON_GITHUB_TOKEN=
CODEXMON_GITHUB_API_BASE=https://api.github.com
CODEXMON_GITHUB_BASE_BRANCH=main
CODEXMON_LOCAL_CHECK_COMMAND=

# Telegram notifier
CODEXMON_TELEGRAM_BOT_TOKEN=
CODEXMON_TELEGRAM_API_BASE=https://api.telegram.org
CODEXMON_TELEGRAM_CHAT_ID=
